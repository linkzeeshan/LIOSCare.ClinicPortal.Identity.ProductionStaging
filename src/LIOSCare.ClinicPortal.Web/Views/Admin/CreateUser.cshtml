@model CreateUserVm
@{ ViewData["Title"] = "Create Clinic User"; }
<form asp-action="CreateUser" method="post" class="card form">@Html.AntiForgeryToken()<div asp-validation-summary="ModelOnly" class="validation"></div><div class="form-grid"><label>Full Name<input asp-for="FullName" /></label><label>Email<input asp-for="Email" /></label><label>Password<input asp-for="Password" type="password" /></label><label>Role<select asp-for="Role"><option value="Admin">Admin</option><option value="Doctor">Doctor</option></select></label></div><button class="btn btn-primary">Create User</button></form>
