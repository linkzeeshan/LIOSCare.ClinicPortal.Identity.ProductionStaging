@model DoctorFormVm
@{ ViewData["Title"] = Model.Id.HasValue ? "Edit Doctor" : "Add Doctor"; }
<form asp-action="Doctor" method="post" class="card form">@Html.AntiForgeryToken()<input asp-for="Id" type="hidden"/><input asp-for="UserId" type="hidden"/><div asp-validation-summary="ModelOnly" class="validation"></div><div class="form-grid"><label>Full Name<input asp-for="FullName" /></label><label>Email<input asp-for="Email" /></label><label>Password<input asp-for="Password" type="password" placeholder="Only required for new doctor"/></label><label>Display Name<input asp-for="DisplayName" /></label><label>Specializations<input asp-for="SpecializationsCsv" /></label><label>Years Experience<input asp-for="YearsExperience" type="number" /></label><label>License Number<input asp-for="LicenseNumber" /></label><label>Currency<input asp-for="Currency" /></label><label>Chat Price<input asp-for="ChatSessionPrice" type="number" step="0.01" /></label><label>Online Consultation Price<input asp-for="OnlineConsultationPrice" type="number" step="0.01" /></label><label>Chat Minutes<input asp-for="ChatSessionMinutes" type="number" /></label><label>Online Minutes<input asp-for="OnlineConsultationMinutes" type="number" /></label><label>Max Chat Sessions<input asp-for="MaxConcurrentSessions" type="number" max="3" /></label><label>Working Days<input asp-for="WorkingDaysCsv" /></label><label>Start Time<input asp-for="WorkStartTime" type="time" /></label><label>End Time<input asp-for="WorkEndTime" type="time" /></label></div><label>Bio<textarea asp-for="Bio" rows="4"></textarea></label><label class="check"><input asp-for="IsAvailable" /> Available</label><button class="btn btn-primary">Save Doctor</button></form>
