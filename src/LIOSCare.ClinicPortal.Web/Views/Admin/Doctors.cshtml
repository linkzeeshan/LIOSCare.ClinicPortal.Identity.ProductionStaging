@model IReadOnlyList<DoctorVm>
@{ ViewData["Title"] = "Clinic Doctors"; }
@section Actions{<a class="btn btn-primary" asp-action="Doctor">Add Doctor</a>}
<section class="card"><table class="table"><thead><tr><th>Doctor</th><th>Specialization</th><th>Packages</th><th>Sessions</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var d in Model){<tr><td><strong>@d.DisplayName</strong><small>@d.LicenseNumber</small></td><td>@string.Join(", ", d.Specializations)</td><td>Chat $@d.ChatPrice<br/>Online $@d.ConsultationPrice</td><td>Max @d.MaxConcurrentSessions</td><td><span class="badge @d.Status.ToLower()">@d.Status</span></td><td><a asp-action="Doctor" asp-route-id="@d.Id">Edit</a><form asp-action="SetDoctorStatus" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@d.Id"/><input type="hidden" name="status" value="Active"/><button class="link">Approve</button></form><form asp-action="SetDoctorStatus" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@d.Id"/><input type="hidden" name="status" value="Inactive"/><button class="link danger">Deactivate</button></form></td></tr>}</tbody></table></section>
