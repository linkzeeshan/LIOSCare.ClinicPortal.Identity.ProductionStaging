@model SessionReportFormVm
@{ ViewData["Title"] = "New Session Report"; }
<form asp-action="NewReport" method="post" class="card form">@Html.AntiForgeryToken()<input asp-for="ChatSessionId" type="hidden"/><div class="confidential"><i class="bi bi-lock"></i> Private & Confidential — patient visible report.</div><div class="form-grid"><label>Mood Before<input asp-for="MoodBefore" type="number" min="1" max="10"/></label><label>Mood After<input asp-for="MoodAfter" type="number" min="1" max="10"/></label><label>Goals Completed<input asp-for="GoalsCompleted" type="number"/></label><label>Goals Total<input asp-for="GoalsTotal" type="number"/></label></div><label>Progress Notes<textarea asp-for="ProgressNotes" rows="7"></textarea></label><label>Techniques Used<input asp-for="TechniquesUsedCsv" placeholder="CBT, Breathing, Journaling"/></label><label>Next Steps<textarea asp-for="NextSteps" rows="3"></textarea></label><button class="btn btn-primary">Save Report</button></form>
