@model IReadOnlyList<JobVm>
@{ ViewData["Title"] = "New Job Offers"; }
<section class="job-grid">@foreach(var j in Model){<article class="job-card"><div class="job-top"><span class="badge violet">@j.JobType</span><span class="expires">Expires @j.OfferExpiresAt.LocalDateTime.ToString("HH:mm")</span></div><h2>@j.AnonymousPatient</h2><p>@j.Note</p><div class="job-actions"><form asp-action="AcceptJob" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@j.Id"/><button class="btn btn-primary">Accept</button></form><form asp-action="RejectJob" method="post">@Html.AntiForgeryToken()<input type="hidden" name="JobId" value="@j.Id"/><input name="Reason" placeholder="Reason"/><button class="btn btn-ghost">Reject</button></form></div></article>}</section>@if(!Model.Any()){<div class="empty"><i class="bi bi-inbox"></i><h2>No active offers</h2><p>New anonymous patient requests will appear here.</p></div>}
