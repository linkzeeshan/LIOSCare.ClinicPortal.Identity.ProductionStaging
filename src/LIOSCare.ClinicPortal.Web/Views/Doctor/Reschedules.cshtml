@model IReadOnlyList<RescheduleVm>
@{ ViewData["Title"] = "Reschedule Requests"; }

@if (!Model.Any())
{
    <partial name="_EmptyState" model='new EmptyStateVm("No reschedule requests", "Patients can request a new time for their session. Those requests will appear here.", "bi-calendar-event")' />
}
else
{
    <div class="responsive-table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Requested Time</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td data-label="Patient"><strong>@r.AnonymousPatient</strong></td>
                        <td data-label="Requested Time">@r.RequestedStartAt.LocalDateTime.ToString("MMM dd HH:mm")</td>
                        <td data-label="Reason">@r.Reason</td>
                        <td data-label="Status"><span class="badge">@r.Status</span></td>
                        <td data-label="Actions" class="actions">
                            <form asp-action="RespondReschedule" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <input type="hidden" name="approve" value="true" />
                                <button class="btn btn-modern btn-modern-primary"><i class="bi bi-check-lg"></i> Approve</button>
                            </form>
                            <form asp-action="RespondReschedule" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id" />
                                <input type="hidden" name="approve" value="false" />
                                <button class="btn btn-modern btn-modern-ghost"><i class="bi bi-x-lg"></i> Reject</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
