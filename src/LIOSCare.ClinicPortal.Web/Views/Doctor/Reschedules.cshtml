@model IReadOnlyList<RescheduleVm>
@{ ViewData["Title"] = "Reschedule Requests"; }
<section class="card"><table class="table"><thead><tr><th>Patient</th><th>Requested Time</th><th>Reason</th><th>Status</th><th></th></tr></thead><tbody>@foreach(var r in Model){<tr><td>@r.AnonymousPatient</td><td>@r.RequestedStartAt.LocalDateTime.ToString("MMM dd HH:mm")</td><td>@r.Reason</td><td>@r.Status</td><td><form asp-action="RespondReschedule" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@r.Id"/><input type="hidden" name="approve" value="true"/><button class="link">Approve</button></form><form asp-action="RespondReschedule" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@r.Id"/><input type="hidden" name="approve" value="false"/><button class="link danger">Reject</button></form></td></tr>}</tbody></table></section>
