@model IReadOnlyList<MetricVm>
@{ ViewData["Title"] = "Doctor Home"; }
<partial name="_Metrics" model="Model" />

<div class="grid-2">
    <article class="card-modern">
        <h3><i class="bi bi-briefcase"></i> Doctor Workspace</h3>
        <p>Accept anonymous patient jobs, manage live chat sessions, respond to reschedules, and create confidential reports.</p>
        <a class="btn btn-modern btn-modern-primary" asp-action="Jobs">
            <i class="bi bi-broadcast"></i> View Job Offers
        </a>
    </article>
    <article class="card-modern">
        <h3><i class="bi bi-shield-check"></i> Operating Rules</h3>
        <ul class="clean">
            <li>Maximum 3 active chat sessions</li>
            <li>Maximum 1 online consultation</li>
            <li>Sessions close automatically after booked duration</li>
            <li>Patient identity remains anonymous</li>
        </ul>
    </article>
</div>
