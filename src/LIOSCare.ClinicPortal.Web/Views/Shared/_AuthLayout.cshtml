@using System.Security.Claims
@{
    var title = ViewData["Title"]?.ToString() ?? "LIOSCare Portal";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - LIOSCare Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/ui-components.css" rel="stylesheet" asp-append-version="true" />
    @RenderSection("Styles", false)
</head>
<body>
    <div class="auth-shell">
        <header class="auth-topbar">
            <a href="/" class="auth-brand">
                <div class="brand-logo"><img src="~/logo/LIO.jpeg" alt="LIOSCare logo" /></div>
                <div>
                    <strong>LIOSCare</strong>
                    <span>Clinic Operations</span>
                </div>
            </a>
        </header>
        <main class="auth-main">
            @RenderBody()
        </main>
        <footer class="auth-footer">
            <span>&copy; @DateTime.UtcNow.Year LIOSCare. All rights reserved.</span>
            <span class="auth-footer-links">
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Support</a>
            </span>
        </footer>
    </div>
    <!-- Hidden logout form -->
    <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display: none;">
        @Html.AntiForgeryToken()
    </form>

    <!-- Logout Confirmation Modal -->
    <div id="logoutModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Confirm Logout</h3>
                <button type="button" class="modal-close" onclick="closeLogoutModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to sign out?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeLogoutModal()">Cancel</button>
                <button type="button" class="btn btn-danger" onclick="performLogout()">
                    <i class="bi bi-box-arrow-left"></i> Sign out
                </button>
            </div>
        </div>
    </div>

    <script>
        function confirmLogout() {
            document.getElementById('logoutModal').style.display = 'flex';
        }
        function closeLogoutModal() {
            document.getElementById('logoutModal').style.display = 'none';
        }
        function performLogout() {
            document.getElementById('logoutForm').submit();
        }
        window.onclick = function(event) {
            const modal = document.getElementById('logoutModal');
            if (event.target === modal) closeLogoutModal();
        }
    </script>
    <script src="~/js/ui-components.js" asp-append-version="true"></script>
    <script src="~/js/auth.js" asp-append-version="true"></script>
    @RenderSection("Scripts", false)
</body>
</html>
