@{ ViewData["Title"] = "Error"; }

<div class="error-container">
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <div class="error-content">
            <h2>@(string.IsNullOrEmpty(ViewBag.ErrorMessage) ? "We couldn't complete that request" : "Profile Configuration Required")</h2>
            <p>
                @(string.IsNullOrEmpty(ViewBag.ErrorMessage) ? "An unexpected error occurred. Please try again or contact your administrator if the issue persists." : ViewBag.ErrorMessage)
            </p>

            <span class="error-code">Error Reference: @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss UTC")</span>

            <div class="error-actions">
                @if (User?.Identity?.IsAuthenticated == true)
                {
                    <a href="/" class="btn btn-primary">
                        <i class="bi bi-house"></i> Go to Dashboard
                    </a>
                    <button type="button" class="btn btn-secondary" onclick="confirmLogout()">
                        <i class="bi bi-box-arrow-left"></i> Sign out
                    </button>
                }
                else
                {
                    <a href="/account/login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right"></i> Sign in
                    </a>
                    <button onclick="history.back()" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Go Back
                    </button>
                }
            </div>
        </div>
    </div>
</div>
