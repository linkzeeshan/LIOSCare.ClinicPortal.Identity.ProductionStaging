@using System.Security.Claims
@{
    var title = ViewData["Title"]?.ToString() ?? "Dashboard";
    var isAuthPage = string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Account", StringComparison.OrdinalIgnoreCase);
    var name = User.FindFirst("full_name")?.Value ?? User.Identity?.Name ?? "User";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - LIOSCare Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/layout-enhancements.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/css/ui-components.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
@if (isAuthPage && !User.Identity!.IsAuthenticated)
{
    @RenderBody()
}
else
{
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand"><div class="brand-logo"><img src="~/logo/LIO.jpeg" alt="LIOSCare logo" /></div><div><strong>LIOSCare</strong><span>Clinic Operations</span></div></div>
            <nav class="nav-section">
                @if (User.IsInRole("SuperAdmin"))
                {
                    <a asp-controller="SuperAdmin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Executive Dashboard</a>
                    <a asp-controller="SuperAdmin" asp-action="Facilities"><i class="bi bi-buildings"></i> Clinics / Hospitals</a>
                    <a asp-controller="SuperAdmin" asp-action="SuperAdmins"><i class="bi bi-shield-lock"></i> Super Admins</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-grid-1x2"></i> Clinic Dashboard</a>
                    <a asp-controller="Admin" asp-action="Doctors"><i class="bi bi-person-vcard"></i> Doctors</a>
                    <a asp-controller="Admin" asp-action="CreateUser"><i class="bi bi-people"></i> Clinic Users</a>
                }
                @if (User.IsInRole("Doctor"))
                {
                    <a asp-controller="Doctor" asp-action="Dashboard"><i class="bi bi-house-heart"></i> Doctor Home</a>
                    <a asp-controller="Doctor" asp-action="Jobs"><i class="bi bi-broadcast"></i> Job Offers</a>
                    <a asp-controller="Doctor" asp-action="Sessions"><i class="bi bi-chat-dots"></i> Chat Sessions</a>
                    <a asp-controller="Doctor" asp-action="History"><i class="bi bi-clock-history"></i> Chat History</a>
                    <a asp-controller="Doctor" asp-action="Reschedules"><i class="bi bi-calendar-event"></i> Reschedule</a>
                    <a asp-controller="Doctor" asp-action="Notifications"><i class="bi bi-bell"></i> Notifications</a>
                }
            </nav>
            <div class="privacy-card"><i class="bi bi-incognito"></i><div><strong>Patient anonymity</strong><span>Doctors see anonymous patient labels only.</span></div></div>
            
            <!-- User Profile Section -->
            <div class="user-profile-section">
                <div class="profile-card">
                    <div class="profile-info">
                        <div class="avatar">@name.Substring(0,1)</div>
                        <div class="profile-details">
                            <div class="profile-name">@name</div>
                            <div class="profile-role">@(User.IsInRole("SuperAdmin") ? "Super Admin" : User.IsInRole("Admin") ? "Administrator" : "Doctor")</div>
                        </div>
                    </div>
                    <div class="profile-actions">
                        <a asp-controller="Profile" asp-action="Index" class="btn btn-sm btn-outline">
                            <i class="bi bi-person"></i> Profile
                        </a>
                        <button type="button" class="btn btn-sm btn-ghost" onclick="confirmLogout()">
                            <i class="bi bi-box-arrow-left"></i> Logout
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Hidden Logout Form -->
            <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display: none;">
                @Html.AntiForgeryToken()
            </form>
        </aside>
        <main class="main">
            <header class="topbar"><button class="mobile-menu" data-menu><i class="bi bi-list"></i></button><div class="search"><i class="bi bi-search"></i><span>Search clinics, doctors, sessions, jobs...</span></div><div class="profile-chip"><span>@name</span><div class="avatar">@name.Substring(0,1)</div></div></header>
            <section class="page">
                <div class="page-title"><div><p>Production staging workspace</p><h1>@title</h1></div>@RenderSection("Actions", false)</div>
                @RenderBody()
            </section>
        </main>
    </div>
}
<style>
    #logoutModal.modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 10000;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(4px);
        padding: 1rem;
    }
    #logoutModal .modal-content {
        background: #fff;
        border-radius: 14px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        overflow: hidden;
    }
    #logoutModal .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
    }
    #logoutModal .modal-header h3 { margin: 0; font-size: 1.1rem; font-weight: 700; color: #0f172a; }
    #logoutModal .modal-close {
        background: none; border: none; font-size: 1.5rem; color: #64748b; cursor: pointer;
        width: 32px; height: 32px; border-radius: 6px; transition: background 0.2s;
    }
    #logoutModal .modal-close:hover { background: #f1f5f9; color: #0f172a; }
    #logoutModal .modal-body { padding: 1.5rem; color: #475569; font-size: 0.95rem; }
    #logoutModal .modal-footer {
        display: flex; justify-content: flex-end; gap: 0.75rem;
        padding: 1rem 1.5rem 1.5rem;
    }
    #logoutModal .btn-danger {
        background: #dc2626; color: #fff; border: none; padding: 0.75rem 1.25rem;
        border-radius: 8px; font-weight: 600; cursor: pointer;
    }
    #logoutModal .btn-danger:hover { background: #b91c1c; }
    #logoutModal .btn-secondary {
        background: #f1f5f9; color: #334155; border: 1px solid #e2e8f0;
        padding: 0.75rem 1.25rem; border-radius: 8px; font-weight: 600; cursor: pointer;
    }
    #logoutModal .btn-secondary:hover { background: #e2e8f0; }
</style>

<!-- Logout Confirmation Modal -->
<div id="logoutModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Confirm Logout</h3>
            <button type="button" class="modal-close" onclick="closeLogoutModal()">&times;</button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to logout from your account?</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeLogoutModal()">Cancel</button>
            <button type="button" class="btn btn-danger" onclick="performLogout()">
                <i class="bi bi-box-arrow-left"></i> Logout
            </button>
        </div>
    </div>
</div>

<script>
function confirmLogout() {
    document.getElementById('logoutModal').style.display = 'flex';
}

function closeLogoutModal() {
    document.getElementById('logoutModal').style.display = 'none';
}

function performLogout() {
    document.getElementById('logoutForm').submit();
}

// Close modal when clicking outside
window.onclick = function(event) {
    const modal = document.getElementById('logoutModal');
    if (event.target == modal) {
        closeLogoutModal();
    }
}
</script>

<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/ui-components.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", false)
</body>
</html>
