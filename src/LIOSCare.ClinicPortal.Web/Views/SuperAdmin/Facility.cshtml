@model ClinicHospital?
@{ ViewData["Title"] = Model == null ? "Register Clinic/Hospital" : "Edit Clinic/Hospital"; }
<form asp-action="Facility" method="post" class="card form">@Html.AntiForgeryToken()<input type="hidden" name="Id" value="@Model?.Id"/><div class="form-grid"><label>Name<input name="Name" value="@Model?.Name" required /></label><label>Type<select name="Type"><option>Clinic</option><option>Hospital</option></select></label><label>Contact Email<input name="ContactEmail" value="@Model?.ContactEmail" required /></label><label>Contact Phone<input name="ContactPhone" value="@Model?.ContactPhone" required /></label><label>City<input name="City" value="@Model?.City" required /></label><label>Country<input name="Country" value="@Model?.Country" required /></label></div><label>Address<textarea name="Address" rows="4">@Model?.Address</textarea></label><button class="btn btn-primary">Save Facility</button></form>
