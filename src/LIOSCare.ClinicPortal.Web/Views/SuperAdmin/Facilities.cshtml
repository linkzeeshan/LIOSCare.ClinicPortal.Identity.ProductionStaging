@model IReadOnlyList<FacilityVm>
@{ ViewData["Title"] = "Clinics / Hospitals"; }
@section Actions{<a class="btn btn-primary" asp-action="Facility">Register Clinic/Hospital</a>}
<section class="card"><table class="table"><thead><tr><th>Name</th><th>Type</th><th>Status</th><th>Location</th><th>Contact</th><th>Actions</th></tr></thead><tbody>@foreach(var f in Model){<tr><td><strong>@f.Name</strong></td><td>@f.Type</td><td><span class="badge @f.Status.ToLower()">@f.Status</span></td><td>@f.City, @f.Country</td><td>@f.ContactEmail</td><td><a asp-action="Facility" asp-route-id="@f.Id">Edit</a><form asp-action="SetFacilityStatus" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@f.Id"/><input type="hidden" name="status" value="Approved"/><button class="link">Approve</button></form><form asp-action="SetFacilityStatus" method="post" class="inline">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@f.Id"/><input type="hidden" name="status" value="Inactive"/><button class="link danger">Deactivate</button></form></td></tr>}</tbody></table></section>
